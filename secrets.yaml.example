# ============================================================
#  SECRETS FILE — homelab-esp32
# ============================================================
#  INSTRUCTIONS:
#  1. Copy this file: cp secrets.yaml.example secrets.yaml
#  2. Fill in YOUR values below (replace everything in quotes)
#  3. NEVER commit secrets.yaml to git (it's already in .gitignore)
# ============================================================

# ============================================================
# WIFI — Your IoT network (VLAN 5 in your UniFi setup)
# ============================================================
# This is the SSID you created in UniFi for IoT devices (VLAN 5).
# If you haven't created a separate IoT SSID yet, use your main WiFi for now.
wifi_ssid: "YOUR_IOT_WIFI_SSID"
wifi_password: "YOUR_WIFI_PASSWORD"

# Fallback hotspot password — used if the board can't reach your WiFi.
# You can connect to this hotspot to fix the board. Can be anything.
wifi_fallback_password: "homelabfallback"

# ============================================================
# HOME ASSISTANT API KEY
# ============================================================
# This is an encryption key for the ESP32 <-> HA connection.
# Generate one here: https://esphome.io/components/api.html#configuration-variables
# Or run this command on any machine with Python:
#   python3 -c "import secrets; print(secrets.token_urlsafe(32))"
# Example output looks like: dGVzdGtleWZvcmNpdGVzdGluZ29ubHkxMjM0NTY3
ha_api_key: "YOUR_GENERATED_API_KEY_HERE"

# Password used when pushing new firmware over WiFi (OTA updates).
# Can be anything — just remember it.
ha_ota_password: "YOUR_OTA_PASSWORD"

# ============================================================
# MQTT BROKER
# ============================================================
# Your Home Assistant MQTT broker (Mosquitto).
# The IP is your HA server on VLAN 50.
mqtt_broker: "192.168.50.127"
mqtt_username: "homelab"
mqtt_password: "YOUR_MQTT_PASSWORD"

# ============================================================
# INFLUXDB (for Grafana dashboards on CT109)
# ============================================================
influxdb_host: "192.168.10.83"
influxdb_port: "8086"
influxdb_db: "esp32_sensors"
influxdb_username: "esp32"
influxdb_password: "YOUR_INFLUXDB_PASSWORD"
