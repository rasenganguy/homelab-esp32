# ESPHome Secrets File
# Copy this to your ESPHome config directory as secrets.yaml
# Do NOT commit the real secrets.yaml to git - it's in .gitignore

wifi_ssid: "YOUR_IOT_WIFI_SSID"
wifi_password: "YOUR_WIFI_PASSWORD"
wifi_fallback_password: "homelab-fallback"

# Home Assistant
ha_api_key: "YOUR_HA_API_ENCRYPTION_KEY"  # Generate with: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
ha_ota_password: "YOUR_OTA_PASSWORD"

# MQTT (if using MQTT instead of native API)
mqtt_broker: "192.168.50.127"
mqtt_username: "homelab"
mqtt_password: "YOUR_MQTT_PASSWORD"

# InfluxDB (for Grafana)
influxdb_host: "192.168.10.83"
influxdb_port: "8086"
influxdb_db: "esp32_sensors"
influxdb_username: "esp32"
influxdb_password: "YOUR_INFLUXDB_PASSWORD"
